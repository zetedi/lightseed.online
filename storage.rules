rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is a staff member
    function isStaff() {
      return request.auth != null && 
        (request.auth.token.email == 'zetedi@gmail.com' || 
         firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)));
    }

    function ownsCommunity(communityId) {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/communities/$(communityId)) &&
        firestore.get(/databases/(default)/documents/communities/$(communityId)).data.ownerId == request.auth.uid;
    }

    // Global rules for reading and staff writing
    match /{allPaths=**} {
      // Allow public reading of all images
      allow read: if true;
      // Allow staff to write anywhere (for administrative tasks)
      allow write: if isStaff();
    }

    // Specific rules for user-owned folders
    match /users/{userId}/{allPaths=**} {
      // Allow users to write to their own folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Community owners can manage their own white-label assets and event galleries
    match /communities/{communityId}/{allPaths=**} {
      allow write: if isStaff() || ownsCommunity(communityId);
    }

    // Org-collab logos — adding an org is member-wide (see firestore collabs rules), so any
    // signed-in member may upload a logo for one.
    match /collabs/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}

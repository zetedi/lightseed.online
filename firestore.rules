
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isRootSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'zetedi@gmail.com';
    }

    function isConfiguredSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/config/superadmin)
        && get(/databases/$(database)/documents/config/superadmin).data.uid == request.auth.uid;
    }

    function isSuperAdmin() {
      return isRootSuperAdmin() || isConfiguredSuperAdmin();
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isStaff() {
      return isSuperAdmin() || isAdmin();
    }
    
    // Allow users to access their own profile
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Email System: 
    // Create: Auth users can trigger emails, BUT must include their uid so they can read it back.
    // Read: Users can read their own email logs to check delivery status.
    // We allow reading if resource is null to handle the race condition where the client listens before the server commits the write.
    match /mail/{mailId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
    }

    // Newsletter: Public write access for signups
    match /subscriptions/{subId} {
      allow create: if true;
      allow update: if isSignedIn();
      allow delete: if (isSignedIn() && resource.data.uid == request.auth.uid) || isStaff();
      allow read: if isStaff();
    }

    match /admins/{adminId} {
      allow read: if isStaff();
      allow write: if isSuperAdmin();
    }

    match /config/{configId} {
      allow read: if isStaff();
      allow write: if isSuperAdmin();
    }

    // Lifetrees: Read public, Write auth
    match /lifetrees/{treeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Visions: Read public, Write auth
    match /visions/{visionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pulses: Read public, Write auth
    match /pulses/{pulseId} {
      allow read: if true;
      allow write: if request.auth != null;

      // Subcollection for Loves
      match /loves/{userId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Matches: Read public, Write auth
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}

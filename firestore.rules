rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    function isStaff() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || request.auth.token.admin == true;
    }
    function isCommunityOwner(communityId) {
      return communityId is string &&
        exists(/databases/$(database)/documents/communities/$(communityId)) &&
        get(/databases/$(database)/documents/communities/$(communityId)).data.ownerId == request.auth.uid;
    }

    // Admins collection: read staff, no direct write
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    // Config collection: read staff/config-specific, no direct write
    match /config/{configId} {
      allow read: if configId == 'superadmin' || isStaff();
      allow write: if false; 
    }

    // Users collection: Read self/staff, Write self
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow write: if isOwner(userId);
    }

    // Subscriptions: Create public, Read staff
    match /subscriptions/{subId} {
      allow read: if isStaff();
      allow create: if true;
      allow update, delete: if isStaff();
    }

    // Mail: Read/Write self/staff
    match /mail/{mailId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isStaff());
      allow create: if isSignedIn();
      allow delete: if isStaff();
    }

    // Lifetrees: Read public, Write owner/staff
    match /lifetrees/{treeId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaff() || request.auth.uid in resource.data.guardians);
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaff());
    }

    // Visions: Read public, Write author/staff
    match /visions/{visionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // For joining
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isStaff());
    }

    // Pulses: Read public, Write signed in
    match /pulses/{pulseId} {
      allow read: if true;
      allow create: if isSignedIn() && (
        request.resource.data.type != 'event' ||
        isStaff() ||
        isCommunityOwner(request.resource.data.communityId)
      );
      allow update: if isSignedIn(); // For loves
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isStaff());

      // Loves subcollection
      match /loves/{loveId} {
          allow read: if true;
          allow write: if isSignedIn() && isOwner(loveId);
      }
    }

    // Alignments: Read public, Write signed in
    match /alignments/{id} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.targetUid == request.auth.uid || resource.data.initiatorUid == request.auth.uid);
      allow delete: if isStaff();
    }

    // Communities: Read public, Write staff/owner
    match /communities/{communityId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaff());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isStaff());
    }
  }
}
